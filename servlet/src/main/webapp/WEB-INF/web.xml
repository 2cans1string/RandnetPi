<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <servlet>
        <servlet-name>CheckMember</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.CheckMemberServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckMember</servlet-name>
        <url-pattern>/servlet/CheckMember</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetCommunicationConfig</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.GetCommunicationConfigServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetCommunicationConfig</servlet-name>
        <url-pattern>/servlet/GetCommunicationConfig</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetNewVersion</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.GetNewVersionServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetNewVersion</servlet-name>
        <url-pattern>/servlet/GetNewVersion</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckCreditPW</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.CheckCreditPWServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckCreditPW</servlet-name>
        <url-pattern>/servlet/CheckCreditPW</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UseMail</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.UseMailServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>UseMail</servlet-name>
        <url-pattern>/servlet/UseMail</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ChangeMailPassword</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.ChangeMailPasswordServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChangeMailPassword</servlet-name>
        <url-pattern>/servlet/ChangeMailPassword</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StaticContent</servlet-name>
        <servlet-class>jp.ne.randnet.servlet.StaticContentServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaticContent</servlet-name>
        <url-pattern>/v/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaticContent</servlet-name>
        <url-pattern>/help/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaticContent</servlet-name>
        <url-pattern>/html/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaticContent</servlet-name>
        <url-pattern>/randnetdd/*</url-pattern>
    </servlet-mapping>

</web-app>
